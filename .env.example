SITE_URL=https://www.obbacalculators.com

# Enable local/self-hosted file storage for subscribers.
# On Vercel, use SUBSCRIBERS_WEBHOOK_URL or an external database because serverless files are not persistent.
SUBSCRIBERS_STORE=file
SUBSCRIBERS_DATA_DIR=./data
WELCOME_EMAIL_QUEUE_FILE=./data/welcome-email-queue.jsonl

# Used to sign unsubscribe links. Generate a long random value.
EMAIL_SECRET=replace-with-a-long-random-secret

# Gmail SMTP account. Use a Google App Password, not the normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=obbacalculators@gmail.com
SMTP_PASS=your-google-app-password
MAIL_FROM="OBBA Calculators <obbacalculators@gmail.com>"
WELCOME_CRON_SECRET=change-this-private-worker-secret
MAIL_WORKER_SECRET=change-this-private-mail-worker-secret
MAIL_BATCH_LIMIT=10
UPSTASH_QSTASH_TOKEN=your-upstash-qstash-token
QSTASH_MOCK=false
ADMIN_EMAIL=obbacalculators@gmail.com
ADMIN_SECRET=change-this-private-admin-secret
MAIL_CAMPAIGN_DIR=./data/mail-campaigns
MAIL_SEND_LOG_FILE=./data/mail-send-log.jsonl
ADMIN_CONFIG_FILE=./data/admin-config.json
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: send one test email without using subscriber list.
NEWSLETTER_TEST_TO=your-email@example.com
