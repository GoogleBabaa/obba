{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/overtime", "destination": "/overtime/index.html" },
    { "source": "/salary-calculator", "destination": "/salary-calculator/index.html" },
    { "source": "/paycheck-calculator", "destination": "/paycheck-calculator/index.html" },
    { "source": "/texas-paycheck-calculator", "destination": "/texas-paycheck-calculator/index.html" },
    { "source": "/florida-paycheck-calculator", "destination": "/florida-paycheck-calculator/index.html" },
    { "source": "/california-paycheck-calculator", "destination": "/california-paycheck-calculator/index.html" },
    { "source": "/illinois-paycheck-calculator", "destination": "/illinois-paycheck-calculator/index.html" },
    { "source": "/washington-paycheck-calculator", "destination": "/washington-paycheck-calculator/index.html" },
    { "source": "/indiana-paycheck-calculator", "destination": "/indiana-paycheck-calculator/index.html" },
    { "source": "/virginia-paycheck-calculator", "destination": "/virginia-paycheck-calculator/index.html" },
    { "source": "/hawaii-paycheck-calculator", "destination": "/hawaii-paycheck-calculator/index.html" },
